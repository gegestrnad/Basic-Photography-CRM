# ── Local development ─────────────────────────────────────────────────
# This .env is for local dev only. Vercel uses its own env vars (set in
# the Vercel dashboard). See DEPLOY.md for Vercel setup.
#
# LOCAL DEV: SQLite (default — no external database needed)
DATABASE_URL=file:./db/custom.db

# PRODUCTION (Vercel): Change prisma/schema.prisma provider to "postgresql"
# and set DATABASE_URL to your hosted PostgreSQL connection string, e.g.:
#   DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

NEXTAUTH_SECRET=photography-client-management-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000
